# Builder.io
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__

# Development
PING_MESSAGE="ping pong"

# Supabase Configuration
# Get these from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (for server-side operations)
# ⚠️ Keep this secret! Only use on server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email Configuration (Optional - will use test emails if not provided)
# For production, configure SMTP settings:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password
EMAIL_FROM="Nexamap <noreply@nexamap.com.au>"

# Google Maps API (for address autocomplete)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Error Monitoring (recommended for production)
VITE_SENTRY_DSN=your-sentry-dsn

# Production Domain (for CORS)
FRONTEND_URL=https://your-domain.com

# Additional allowed origins for CORS (comma-separated)
# ADDITIONAL_ORIGINS=https://app.your-domain.com,https://staging.your-domain.com

# Security Configuration
# NODE_ENV=production  # Enable production security settings
